{
  "name": "ubuntu24-asan",
  "image": "ghcr.io/romange/ubuntu-dev:24",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools-themes",
        "twxs.cmake"
      ],
      "settings": {
        "cmake.buildDirectory": "/build",
        "cmake.configureArgs": [
          "-DUSE_MOLD=ON",
          "-DHELIO_USE_SANITIZER=ON",
          "-DWITH_AWS=OFF",
          "-DWITH_GCP=OFF",
          "-DWITH_GPERF=OFF"
        ]
      }
    }
  },
  "mounts": [
    "source=ubuntu24-helio-vol,target=/build,type=volume"
  ],
  "postCreateCommand": ".devcontainer/post-create.sh ${containerWorkspaceFolder}"
}